server {
    listen 80;
    server_name *.zevza.com zevza.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name zevza.com;

    ssl_certificate /etc/letsencrypt/live/zevza.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/zevza.com/privkey.pem;

    root /var/www/sites/zevza/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 443 ssl;
    server_name ~^(?<subdomain>.+)\.zevza\.com$;

    ssl_certificate /etc/letsencrypt/live/zevza.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/zevza.com/privkey.pem;

    root /var/www/sites/$subdomain/dist;
    index index.html;

    # PostgREST API proxy — frontend sets Accept-Profile/Content-Profile headers
    location /api/ {
        rewrite ^/api/(.*) /$1 break;
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
